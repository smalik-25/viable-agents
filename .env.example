# viable-agents environment. Copy to `.env` at the repo root and fill in real
# values. `.env` and `.env.*` are gitignored (except this file).
#
# Nothing here is required for Phase 0. Phase 1 needs DATABASE_URL and, to close
# its exit criteria, the Langfuse keys. Phase 2 needs GITHUB_TOKEN.

# --- Postgres (docker compose up brings this on port 5433) ---------------------
# Port 5433 rather than 5432 so a Postgres already running locally does not
# collide. Postgres is the system of record: every envelope, decision, and LLM
# call is a row here, and the algedonic detectors (Phase 6) and POSIWID auditor
# (Phase 7) read from this database, never from a SaaS API.
DATABASE_URL=postgresql+asyncpg://viable:viable@localhost:5433/viable_agents

# --- Anthropic ------------------------------------------------------------
# Model IDs are NEVER hardcoded; they live in config/models.yaml keyed by VSM
# tier. This key is the only thing that comes from the environment. CI never
# receives it: tests use a scripted client with priced fake responses, and the
# one test that hits the live API carries the `live` marker and is deselected.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Langfuse Cloud -------------------------------------------------------
# Tracing is a viewer, not the system of record. When these are unset the
# tracer is a no-op and everything still runs, which is how CI and the eval
# harness operate. Keys are region-scoped: US keys only authenticate against
# us.cloud.langfuse.com, so LANGFUSE_BASE_URL must match where the project was
# created. The current Python SDK (v4) reads LANGFUSE_BASE_URL; LANGFUSE_HOST is
# a legacy alias.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# --- GitHub (Phase 2, live source) ----------------------------------------
# Fine-grained personal access token, PUBLIC REPOSITORIES, READ-ONLY. It needs
# Actions: read and Contents: read and nothing else. The adapter never writes:
# no PRs, no issues, no comments (CLAUDE.md hard rule 5), so any write scope on
# this token is a bug in how it was minted, not a capability.
GITHUB_TOKEN=github_pat_xxxxxxxx
